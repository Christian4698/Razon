# RAZON production environment example
# Never commit real secrets. Use your host secret manager.

NODE_ENV=production
APP_NAME=RAZON
APP_BASE_URL=https://app.gtc.example
API_BASE_URL=https://app.gtc.example
PORT=3000
TZ=UTC
TRUST_PROXY=true

# Runtime safety: production remains analysis/read-only until an explicit future release changes it.
RAZON_MODE=MODE_ANALYSIS
MODE_SIMULATION=true
SIMULATION_MODE=true
DEMO_MODE=true
DATA_MODE=DEMO_DATA
DEFAULT_DATA_MODE=DEMO_DATA
ALLOW_REAL_DATA=false
ALLOW_LIVE_TRADING=false
ENABLE_LIVE_TRADING=false
ALLOW_AUTO_EXECUTION=false
DERIV_ALLOW_ORDER_PLACEMENT=false
MT5_ALLOW_ORDER_PLACEMENT=false

# Security
APP_SECRET_KEY=replace-with-64-plus-random-characters
JWT_SECRET=replace-with-different-64-plus-random-characters
ENCRYPTION_KEY=replace-with-32-plus-byte-secret
API_KEY_SALT=replace-with-random-salt
CORS_ORIGIN=https://app.gtc.example,https://*.gtc.example
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Auth
AUTH_ACCESS_TTL_SECONDS=900
AUTH_REFRESH_TTL_SECONDS=28800
AUTH_REMEMBER_REFRESH_TTL_SECONDS=2592000
AUTH_RESET_TTL_SECONDS=900
AUTH_LOGIN_WINDOW_MS=300000
AUTH_LOGIN_MAX_ATTEMPTS=8
RAZON_ADMIN_USER_ID=admin
RAZON_ADMIN_USERNAME=admin
RAZON_ADMIN_EMAIL=admin@gtc.example
RAZON_ADMIN_NAME=Razon Admin
RAZON_ADMIN_PASSWORD=replace-with-temporary-admin-password
RAZON_ADMIN_FORCE_PASSWORD_CHANGE=true

# Supabase/Postgres persistence
SAAS_PERSISTENCE=postgres
SAAS_PERSISTENCE_PROVIDER=postgres
SAAS_DB_AUTO_MIGRATE=true
SAAS_PERSISTENCE_FLUSH_DEBOUNCE_MS=75
SUPABASE_PROJECT_REF=pvoztowlhdirmruwanzl
SUPABASE_URL=https://pvoztowlhdirmruwanzl.supabase.co
# Backend-only direct Postgres URL. Store the real value in the host secret manager.
SUPABASE_DB_URL=postgresql://postgres.pvoztowlhdirmruwanzl:<database-password>@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
# Optional alias only when your host requires DATABASE_URL. Do not rely on ${SUPABASE_DB_URL} expansion.
DATABASE_URL=
DATABASE_SSL=true
DATABASE_POOL_MIN=0
DATABASE_POOL_MAX=10
DATABASE_LOG_QUERIES=false

# Connector secrets stay backend-only. Frontend must never receive these values.
DERIV_ENABLED=false
DERIV_APP_ID=
DERIV_API_TOKEN=
DERIV_ENDPOINT=wss://ws.derivws.com/websockets/v3
DERIV_ACCOUNT_TYPE=demo
MT5_ENABLED=false
MT5_MODE=demo
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
FOREX_API_ENABLED=false
FOREX_API_KEY=
FOREX_API_SECRET=

# Storage and audit
STORAGE_ROOT=./storage
LOG_STORAGE_PATH=./storage/logs
AUDIT_LOG_ENABLED=true
JOURNAL_ENABLED=true
SAVE_REJECTED_TRADES=true
SAVE_SIGNAL_SNAPSHOTS=true
