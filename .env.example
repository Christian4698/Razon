# RAZON environment example
# Copy to .env locally. Never commit real secrets.

# Application
NODE_ENV=development
APP_NAME=RAZON
APP_PORT=3000
API_PORT=8787
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8787
LOG_LEVEL=info
TZ=UTC

# Runtime mode
RAZON_MODE=MODE_ANALYSIS
MODE_SIMULATION=true
SIMULATION_MODE=true
DEMO_MODE=true
DEMO_DATA_SOURCE=simulation
DEMO_ACCOUNT_BALANCE=10000
DEMO_CHART_TICK_MS=2400
DATA_MODE=DEMO_DATA
DEFAULT_DATA_MODE=DEMO_DATA
ALLOW_REAL_DATA=false
REQUIRE_DATA_MODE_CONFIRMATION=true
DATA_MODE_CONFIRMATION_PHRASE=JE COMPRENDS
DATA_MODE_CHANGE_AUDIT_ENABLED=true
BLOCK_DATA_MODE_CHANGE_WHILE_ANALYSIS_ACTIVE=true
BLOCK_DATA_MODE_CHANGE_WHILE_TRADE_ACTIVE=true
ALLOW_LIVE_TRADING=false
ENABLE_LIVE_TRADING=false
ALLOW_AUTO_EXECUTION=false
ENABLE_KALOS=false
ENABLE_RISK_ENGINE=false
ENABLE_MARKET_DATA_ENGINE=false

# Security
APP_SECRET_KEY=change-me-long-random-value
JWT_SECRET=change-me-long-random-value
ENCRYPTION_KEY=change-me-32-bytes-minimum
API_KEY_SALT=change-me-random-salt
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
TRUST_PROXY=false

# Authentication
AUTH_ACCESS_TTL_SECONDS=900
AUTH_REFRESH_TTL_SECONDS=28800
AUTH_REMEMBER_REFRESH_TTL_SECONDS=2592000
AUTH_RESET_TTL_SECONDS=900
AUTH_LOGIN_WINDOW_MS=300000
AUTH_LOGIN_MAX_ATTEMPTS=8
RAZON_ADMIN_USER_ID=admin
RAZON_ADMIN_USERNAME=admin
RAZON_ADMIN_EMAIL=admin@razon.local
RAZON_ADMIN_NAME=Razon Admin
RAZON_ADMIN_PASSWORD=
RAZON_ADMIN_FORCE_PASSWORD_CHANGE=false

# Database
SAAS_PERSISTENCE=memory
SAAS_PERSISTENCE_PROVIDER=memory
SAAS_DB_AUTO_MIGRATE=false
SAAS_PERSISTENCE_FLUSH_DEBOUNCE_MS=75
DATABASE_URL=postgresql://razon:razon_password@localhost:5432/razon
SUPABASE_DB_URL=
DATABASE_SSL=false
DATABASE_POOL_MIN=1
DATABASE_POOL_MAX=10
DATABASE_LOG_QUERIES=false

# Storage
STORAGE_ROOT=./storage
LOG_STORAGE_PATH=./storage/logs
MARKET_STORAGE_PATH=./storage/market
JOURNAL_STORAGE_PATH=./storage/journal
SNAPSHOT_STORAGE_PATH=./storage/snapshots

# MetaTrader 5 connector
MT5_ENABLED=false
MT5_MODE=demo
MT5_ACCOUNT_TYPE=demo
MT5_LOGIN=
MT5_ACCOUNT_ID=
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=
MT5_HOST=127.0.0.1
MT5_PORT=443
MT5_BRIDGE_HOST=127.0.0.1
MT5_BRIDGE_PORT=8788
MT5_TIMEOUT_MS=15000
MT5_ALLOW_ORDER_PLACEMENT=false

# Deriv connector
DERIV_ENABLED=false
DERIV_APP_ID=
DERIV_API_TOKEN=
DERIV_ENDPOINT=wss://ws.derivws.com/websockets/v3
DERIV_ACCOUNT_TYPE=demo
DERIV_ALLOW_ORDER_PLACEMENT=false

# Forex API connector
FOREX_API_ENABLED=false
FOREX_API_PROVIDER=
FOREX_API_BASE_URL=
FOREX_API_KEY=
FOREX_API_SECRET=
FOREX_API_TIMEOUT_MS=15000
FOREX_API_RATE_LIMIT_PER_MINUTE=60

# Generic market data connector
GENERIC_MARKET_API_ENABLED=false
GENERIC_MARKET_API_BASE_URL=
GENERIC_MARKET_API_KEY=
GENERIC_MARKET_API_SECRET=
GENERIC_MARKET_API_TIMEOUT_MS=15000

# Risk guardrails
DEFAULT_ACCOUNT_CURRENCY=USD
MAX_RISK_PER_TRADE_PERCENT=1
MAX_DAILY_LOSS_PERCENT=3
MAX_TOTAL_DRAWDOWN_PERCENT=10
MIN_RISK_REWARD_RATIO=2
KILL_SWITCH_ENABLED=true
EMERGENCY_STOP_ENABLED=true
ALLOW_MARTINGALE=false

# Market data defaults
DEFAULT_SYMBOLS=EURUSD,XAUUSD,GBPUSD,USDJPY
DEFAULT_TIMEFRAMES=M1,M5,M15,M30,H1,H4,D1
MARKET_DATA_CACHE_TTL_MS=5000
MARKET_DATA_HISTORY_LIMIT=5000

# Journal and audit
JOURNAL_ENABLED=true
AUDIT_LOG_ENABLED=true
SAVE_REJECTED_TRADES=true
SAVE_SIGNAL_SNAPSHOTS=true

# Backtesting
BACKTEST_ENABLED=false
BACKTEST_DATA_PATH=./storage/market
BACKTEST_REPORT_PATH=./storage/snapshots
